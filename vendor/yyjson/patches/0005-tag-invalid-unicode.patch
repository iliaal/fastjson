--- a/vendor/yyjson/yyjson.c
+++ b/vendor/yyjson/yyjson.c
@@ -4744,6 +4744,7 @@ static_inline bool read_str_opt(u8 quo, u8 **ptr, u8 *eof, yyjson_read_flag flg,
     u8 *src = hdr, *dst = NULL, *pos;
     u16 hi, lo;
     u32 uni, tmp;
+    bool invalid_unicode = false;
 
     /* Resume incremental parsing. */
     if (con && unlikely(con[0])) {
@@ -4806,7 +4807,8 @@ skip_ascii_end:
