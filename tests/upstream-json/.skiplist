serialize.phpt                # ext-json-internals # JsonSerializable mix

# === JsonException class (re-evaluated; 1/3 now passes) ===
# fastjson throws \JsonException as of commit fddc0c6. After also
# implementing decode's JSON_THROW_ON_ERROR and the THROW_ON_ERROR
# "preserve global state" contract, json_exceptions_error_clearing.phpt
# passes. The remaining two failures are pure error-message-text
# divergence (yyjson "unexpected end of data" / "invalid utf-8 encoding
# in string" vs ext/json "Syntax error near location X:Y" / "Malformed
# UTF-8 characters, possibly incorrectly encoded") -- same category
# as the 10 error_location_* tests above.
json_decode_exceptions.phpt # ext-json-internals # error-message text divergence
json_encode_exceptions.phpt # ext-json-internals # error-message text divergence

